<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="css1/style.css">
    <link rel="stylesheet" href="css/bootstrap.min.css">

    <title>About Us - Auto Repair Services</title>
</head>
<body>

    <%-include('partials/navbar')%>
    
    <!-- Hero Section -->
    <section class="hero">
        <div class="hero-bg">
            <img src="/images/Auto-Repair-Career-Aboutpage.webp" alt="Auto Repair Career">
            <div class="hero-bg-overlay"></div>
        </div>
        <div class="hero-content">
            <p class="eyebrow-text text-primary mb-3">About Our Company</p>
            <h1 class="hero-title">Excellence in <span class="text-highlight">Auto Repair</span></h1>
            <p class="hero-subtitle">Professional automotive services with over 10 years of experience</p>
        </div>
    </section>

    <!-- About Section -->
    <section class="about-section py-5">
        <div class="container">
            <div class="row align-items-center g-5">
                
                <div class="col-lg-6">
                    <div class="about-img-container">
                        <img src="/images/Auto-Repair-Career-Aboutpage.webp" alt="About Our Auto Repair Services" class="img-fluid rounded-4 shadow-2xl">
                    </div>
                </div>

                <div class="col-lg-6">
                    <h2 class="section-title">Why Choose <span class="text-highlight">Our Services</span></h2>
                    <p class="lead mb-4">We are committed to providing exceptional automotive repair and maintenance services with a focus on quality, reliability, and customer satisfaction.</p>
                    
                    <div class="vertical-service-list">
                        <% about.forEach(function(item){ %>
                            <div class="service-item mb-4">
                                <div class="service-content">
                                    <h4><%= item.title %></h4>
                                    <p><%= item.description %></p>
                                    <a href="#contact" class="read-more-btn">
                                        <%= item.link %> <span>→</span>
                                    </a>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <!-- Mission & Vision -->
    <section class="mission-vision py-5 bg-light">
        <div class="container">
            <div class="row g-5">
                <div class="col-lg-6">
                    <div class="mission-card p-4 rounded-4 shadow-sm">
                        <h3 class="text-primary mb-3">Our Mission</h3>
                        <p>To deliver reliable, efficient, and affordable automotive repair services that keep our customers safe on the road and extend the life of their vehicles.</p>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="vision-card p-4 rounded-4 shadow-sm">
                        <h3 class="text-primary mb-3">Our Vision</h3>
                        <p>To be the leading automotive service provider in the region, known for our expertise, customer service, and commitment to excellence.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Stats Section -->
    <section class="stats-section py-5">
        <div class="container">
            <div class="row text-center g-4">
                <div class="col-md-3">
                    <div class="stat-item">
                        <h3 class="stat-number">10+</h3>
                        <p class="stat-label">Years Experience</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-item">
                        <h3 class="stat-number">5000+</h3>
                        <p class="stat-label">Happy Customers</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-item">
                        <h3 class="stat-number">50+</h3>
                        <p class="stat-label">Expert Technicians</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-item">
                        <h3 class="stat-number">24/7</h3>
                        <p class="stat-label">Support Available</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <%-include('partials/footer')%>
</body>
<script src="js/bootstrap.bundle.min.js"></script>
</html>