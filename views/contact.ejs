<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="css1/style.css">
    <link rel="stylesheet" href="css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <title>Contact Us - Auto Repair Services</title>
</head>
<body>

    <%-include('partials/navbar')%>

    <!-- Hero Section -->
    <section class="contact-hero">
        <div class="contact-hero-bg">
            <img src="/images/car-engine-in-repair-shop-contactpage.jpg" alt="Car Engine Repair Shop">
            <div class="contact-hero-overlay"></div>
        </div>
        <div class="contact-hero-content">
            <p class="eyebrow-text text-primary mb-3">Get In Touch</p>
            <h1 class="hero-title">Contact <span class="text-highlight">Our Team</span></h1>
            <p class="hero-subtitle">Ready to get your vehicle back on the road? Reach out to us today.</p>
        </div>
    </section>

    <!-- Contact Info Section -->
    <section class="contact-info py-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4">
                    <div class="contact-card">
                        <div class="contact-icon">
                            <i class="fas fa-map-marker-alt"></i>
                        </div>
                        <h4>Visit Our Location</h4>
                        <p>123 Auto Repair Street<br>Car City, CC 12345</p>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="contact-card">
                        <div class="contact-icon">
                            <i class="fas fa-phone"></i>
                        </div>
                        <h4>Call Us</h4>
                        <p>+1 (555) 123-4567<br>+1 (555) 987-6543</p>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="contact-card">
                        <div class="contact-icon">
                            <i class="fas fa-envelope"></i>
                        </div>
                        <h4>Email Us</h4>
                        <p>info@autorepair.com<br>service@autorepair.com</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact Form & Hours -->
    <section class="contact-section py-5">
        <div class="container">
            <div class="row g-5">
                <div class="col-lg-6">
                    <h2 class="section-title mb-4">Send Us a <span class="text-highlight">Message</span></h2>
                    <form class="contact-form">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <input type="text" class="form-control" placeholder="Your Name" required>
                            </div>
                            <div class="col-md-6">
                                <input type="email" class="form-control" placeholder="Your Email" required>
                            </div>
                            <div class="col-12">
                                <input type="text" class="form-control" placeholder="Subject" required>
                            </div>
                            <div class="col-12">
                                <textarea class="form-control" rows="5" placeholder="Your Message" required></textarea>
                            </div>
                            <div class="col-12">
                                <button type="submit" class="btn btn-primary btn-lg">Send Message</button>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="col-lg-6">
                    <h2 class="section-title mb-4">Business <span class="text-highlight">Hours</span></h2>
                    <div class="hours-card">
                        <div class="hours-item">
                            <span class="day">Monday - Friday</span>
                            <span class="time">8:00 AM - 6:00 PM</span>
                        </div>
                        <div class="hours-item">
                            <span class="day">Saturday</span>
                            <span class="time">9:00 AM - 4:00 PM</span>
                        </div>
                        <div class="hours-item">
                            <span class="day">Sunday</span>
                            <span class="time">Closed</span>
                        </div>
                        <div class="hours-item">
                            <span class="day">Emergency Service</span>
                            <span class="time">24/7 Available</span>
                        </div>
                    </div>

                    <div class="emergency-notice mt-4">
                        <h5>Emergency Repairs</h5>
                        <p>For urgent repairs and roadside assistance, call our emergency hotline available 24/7.</p>
                        <a href="tel:+15551234567" class="btn btn-outline-primary">Call Emergency Line</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Map Section -->
    <section class="map-section">
        <div class="container-fluid p-0">
            <div class="map-placeholder">
                <div class="map-overlay">
                    <div class="map-content text-center">
                        <h3>Find Us Here</h3>
                        <p>123 Auto Repair Street, Car City, CC 12345</p>
                        <a href="#" class="btn btn-light">Get Directions</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <%-include('partials/footer')%>
</body>
<script src="js/bootstrap.bundle.min.js"></script>
</html>